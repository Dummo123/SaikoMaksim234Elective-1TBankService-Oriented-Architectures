    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ch_datasource" },
      "description": "Retention Cohort Heatmap. Vertical axis – user cohorts by first activity date. Horizontal – day offset (0..7). Cells show % of users who returned on that day.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "cellOptions": { "type": "color-background", "mode": "gradient" },
            "inspect": false,
            "minWidth": 60
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "dark-red", "value": null },
              { "color": "red", "value": 10 },
              { "color": "orange", "value": 25 },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cohort_date" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "custom.minWidth", "value": 110 },
              { "id": "unit", "value": "string" }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "ch_datasource" },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "WITH first_day AS (\n  SELECT user_id, toDate(min(event_time)) AS cohort\n  FROM raw_events\n  GROUP BY user_id\n),\nactivity AS (\n  SELECT f.cohort, e.user_id, dateDiff('day', f.cohort, e.event_date) AS off\n  FROM raw_events e\n  JOIN first_day f USING (user_id)\n  WHERE off BETWEEN 0 AND 7\n  GROUP BY f.cohort, e.user_id, off\n),\nsizes AS (\n  SELECT cohort, count() AS sz\n  FROM first_day\n  GROUP BY cohort\n)\nSELECT\n  toString(a.cohort) AS cohort_date,\n  round(100.0 * countIf(off = 0) / any(sz), 1) AS \"Day 0\",\n  round(100.0 * countIf(off = 1) / any(sz), 1) AS \"Day 1\",\n  round(100.0 * countIf(off = 2) / any(sz), 1) AS \"Day 2\",\n  round(100.0 * countIf(off = 3) / any(sz), 1) AS \"Day 3\",\n  round(100.0 * countIf(off = 4) / any(sz), 1) AS \"Day 4\",\n  round(100.0 * countIf(off = 5) / any(sz), 1) AS \"Day 5\",\n  round(100.0 * countIf(off = 6) / any(sz), 1) AS \"Day 6\",\n  round(100.0 * countIf(off = 7) / any(sz), 1) AS \"Day 7\"\nFROM activity a\nJOIN sizes s ON a.cohort = s.cohort\nGROUP BY a.cohort\nORDER BY a.cohort DESC\nLIMIT 30",
          "refId": "A"
        }
      ],
      "title": "Retention Cohort Heatmap",
      "type": "table"
    },
    {
